generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  passwordHash         String                @map("password_hash")
  firstName            String                @map("first_name")
  lastName             String                @map("last_name")
  phone                String?               @map("phone")
  profilePicture       String?               @map("profile_picture") @db.NVarChar(Max)
  roleId               String                @map("role_id")
  passwordResetToken          String?               @map("password_reset_token")
  passwordResetExpiry         DateTime?             @map("password_reset_expiry")
  emailVerified               Boolean               @default(false) @map("email_verified")
  verificationToken           String?               @map("verification_token")
  verificationTokenExpiresAt  DateTime?             @map("verification_token_expires_at")
  createdAt                   DateTime              @default(now()) @map("created_at")
  updatedAt                   DateTime              @default(now()) @updatedAt @map("updated_at")
  leaguesAdmin         League[]              @relation("LeagueAdmin")
  tournamentNews       TournamentNews[]
  tournamentOrganizers TournamentOrganizer[]
  tournamentsAdmin     Tournament[]          @relation("TournamentAdmin")
  role                 Role                  @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Role {
  id    String @id @default(uuid())
  name  String @unique
  users User[]

  @@map("roles")
}

model League {
  id          String       @id @default(uuid())
  name        String
  shortName   String?      @map("short_name") @db.NVarChar(20)
  logoUrl     String?      @map("logo_url") @db.NVarChar(Max)
  description String?      @db.NVarChar(Max)
  city        String?      @db.NVarChar(100)
  state       String?      @db.NVarChar(100)
  country     String?      @default("MX") @db.NVarChar(10)
  sport       String?      @default("baseball") @db.NVarChar(20)
  foundedYear Int?         @map("founded_year")
  websiteUrl  String?      @map("website_url") @db.NVarChar(500)
  facebookUrl String?      @map("facebook_url") @db.NVarChar(500)
  isVerified  Boolean      @default(false) @map("is_verified")
  adminId     String       @map("admin_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at")
  admin         User           @relation("LeagueAdmin", fields: [adminId], references: [id])
  tournaments   Tournament[]
  umpires       Umpire[]
  subscriptions Subscription[]

  @@map("leagues")
}

model Tournament {
  id            String                @id @default(uuid())
  name          String
  season        String
  description   String?               @db.NVarChar(Max)
  category      String?
  logoUrl       String?               @map("logo_url") @db.NVarChar(Max)
  rulesType     String                @default("baseball_9") @map("rules_type")
  status        String                @default("upcoming") @db.NVarChar(20)
  startDate     DateTime?             @map("start_date")
  adminId       String                @map("admin_id")
  leagueId      String                @map("league_id")
  locationCity    String?               @map("location_city")
  locationState   String?               @map("location_state")
  locationCountry String?               @map("location_country")
  createdAt       DateTime              @default(now()) @map("created_at")
  fields        Field[]
  games         Game[]
  playerStats   PlayerStat[]
  teams         Team[]
  news          TournamentNews[]
  organizers    TournamentOrganizer[]
  rosterEntries RosterEntry[]
  admin         User                  @relation("TournamentAdmin", fields: [adminId], references: [id], onUpdate: NoAction)
  league        League                @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("tournaments")
}

model TournamentOrganizer {
  id           String     @id @default(uuid())
  tournamentId String     @map("tournament_id")
  userId       String     @map("user_id")
  createdAt    DateTime   @default(now(), map: "to_created_at_df") @map("created_at")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onUpdate: NoAction, map: "to_tournament_id_fkey")
  user         User       @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "to_user_id_fkey")

  @@unique([tournamentId, userId], map: "tournament_organizers_unique")
  @@map("tournament_organizers")
}

model Field {
  id           String     @id @default(uuid())
  name         String
  location     String?
  tournamentId String     @map("tournament_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamsAsHome  Team[]

  @@map("fields")
}

model Team {
  id            String         @id @default(uuid())
  name          String
  shortName     String?        @map("short_name")
  logoUrl       String?        @map("logo_url") @db.NVarChar(Max)
  managerName   String?        @map("manager_name")
  tournamentId  String         @map("tournament_id")
  homeFieldId   String?        @map("home_field_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  gamesAsAway   Game[]         @relation("AwayTeam")
  gamesAsHome   Game[]         @relation("HomeTeam")
  lineupChanges LineupChange[]
  lineups       Lineup[]
  playerStats   PlayerStat[]
  players       Player[]
  rosterEntries RosterEntry[]
  homeField     Field?         @relation(fields: [homeFieldId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tournament    Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("teams")
}

model Player {
  id                     String         @id @default(uuid())
  firstName              String         @map("first_name")
  lastName               String         @map("last_name")
  number                 Int?
  position               String?
  photoUrl               String?        @map("photo_url") @db.NVarChar(Max)
  bats                   String?        @default("R") @db.NVarChar(10)
  throws                 String?        @default("R") @db.NVarChar(10)
  teamId                 String         @map("team_id")
  isVerified             Boolean        @default(false) @map("is_verified")
  verifiedAt             DateTime?      @map("verified_at")
  verificationMethod     String?        @map("verification_method") @db.NVarChar(50)
  createdAt              DateTime       @default(now()) @map("created_at")
  gamesMvp1         Game[]         @relation("GameMvpBatter1")
  gamesMvp2         Game[]         @relation("GameMvpBatter2")
  gamesWonAsPitcher Game[]         @relation("GameWinningPitcher")
  lineupChangesIn   LineupChange[] @relation("LineupChangePlayerIn")
  lineupChangesOut  LineupChange[] @relation("LineupChangePlayerOut")
  lineupEntries     Lineup[]
  playerStats       PlayerStat[]
  team              Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playsAsBatter     Play[]         @relation("BatterPlay")
  playsAsPitcher    Play[]         @relation("PitcherPlay")
  rosterEntries     RosterEntry[]

  @@index([lastName, firstName], map: "players_name_idx")
  @@map("players")
}

model Umpire {
  id          String       @id @default(uuid())
  firstName   String       @map("first_name")
  lastName    String       @map("last_name")
  leagueId    String       @map("league_id")
  gameUmpires GameUmpire[]
  league      League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("umpires")
}

model GameUmpire {
  id        String   @id @default(uuid())
  role      String   @default("plate") @db.NVarChar(100)
  gameId    String   @map("game_id")
  umpireId  String   @map("umpire_id")
  createdAt DateTime @default(now()) @map("created_at")
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  umpire    Umpire   @relation(fields: [umpireId], references: [id], onDelete: Cascade)

  @@unique([gameId, umpireId], map: "game_umpires_unique")
  @@map("game_umpires")
}

model Game {
  id               String         @id @default(uuid())
  field            String?
  scheduledDate    DateTime       @map("scheduled_date")
  startTime        DateTime?      @map("start_time")
  endTime          DateTime?      @map("end_time")
  status           String         @default("scheduled")
  homeScore        Int            @default(0) @map("home_score")
  awayScore        Int            @default(0) @map("away_score")
  currentInning    Int            @default(1) @map("current_inning")
  half             String         @default("top") @db.NVarChar(10)
  maxInnings       Int            @default(7) @map("max_innings")
  tournamentId     String         @map("tournament_id")
  homeTeamId       String         @map("home_team_id")
  awayTeamId       String         @map("away_team_id")
  winningPitcherId String?        @map("winning_pitcher_id")
  mvpBatter1Id     String?        @map("mvp_batter1_id")
  mvpBatter2Id     String?        @map("mvp_batter2_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  umpireBase1        String?        @map("umpire_base1")
  umpireBase2        String?        @map("umpire_base2")
  umpireBase3        String?        @map("umpire_base3")
  umpirePlate        String?        @map("umpire_plate")
  facebookStreamUrl  String?        @map("facebook_stream_url") @db.NVarChar(Max)
  streamStatus       String?        @default("offline") @map("stream_status") @db.NVarChar(20)
  gameUmpires      GameUmpire[]
  awayTeam         Team           @relation("AwayTeam", fields: [awayTeamId], references: [id], onUpdate: NoAction)
  homeTeam         Team           @relation("HomeTeam", fields: [homeTeamId], references: [id], onUpdate: NoAction)
  mvpBatter1       Player?        @relation("GameMvpBatter1", fields: [mvpBatter1Id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mvpBatter2       Player?        @relation("GameMvpBatter2", fields: [mvpBatter2Id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tournament       Tournament     @relation(fields: [tournamentId], references: [id], onUpdate: NoAction)
  winningPitcher   Player?        @relation("GameWinningPitcher", fields: [winningPitcherId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lineupChanges    LineupChange[]
  lineups          Lineup[]
  plays            Play[]

  @@index([tournamentId, status], map: "games_tournament_status_idx")
  @@index([status, createdAt], map: "games_status_created_idx")
  @@index([homeTeamId, awayTeamId], map: "games_teams_idx")
  @@map("games")
}

model Lineup {
  id              String   @id @default(uuid())
  battingOrder    Int      @map("batting_order")
  position        String   @db.NVarChar(10)
  dhForPosition   String?  @map("dh_for_position") @db.NVarChar(10)
  isStarter       Boolean  @default(true) @map("is_starter")
  isActive        Boolean  @default(true) @map("is_active")
  hasUsedReentry  Boolean  @default(false) @map("has_used_reentry")
  gameId          String   @map("game_id")
  teamId          String   @map("team_id")
  playerId        String   @map("player_id")
  createdAt       DateTime @default(now()) @map("created_at")
  game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player          Player   @relation(fields: [playerId], references: [id], onUpdate: NoAction)
  team            Team     @relation(fields: [teamId], references: [id], onUpdate: NoAction)

  @@index([gameId, teamId], map: "lineups_game_team_idx")
  @@map("lineups")
}

model LineupChange {
  id            String   @id @default(uuid())
  changeType    String   @default("SUBSTITUTION") @map("change_type") @db.NVarChar(20)
  battingOrder  Int      @map("batting_order")
  position      String   @db.NVarChar(10)
  dhForPosition String?  @map("dh_for_position") @db.NVarChar(10)
  gameId        String   @map("game_id")
  teamId        String   @map("team_id")
  playerOutId   String?  @map("player_out_id")
  playerInId    String   @map("player_in_id")
  createdAt     DateTime @default(now(), map: "lc_created_at_df") @map("created_at")
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade, map: "lc_game_id_fkey")
  playerIn      Player   @relation("LineupChangePlayerIn", fields: [playerInId], references: [id], onUpdate: NoAction, map: "lc_player_in_id_fkey")
  playerOut     Player?  @relation("LineupChangePlayerOut", fields: [playerOutId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "lc_player_out_id_fkey")
  team          Team     @relation(fields: [teamId], references: [id], onUpdate: NoAction, map: "lc_team_id_fkey")

  @@map("lineup_changes")
}

model PlayerStat {
  id           String      @id @default(uuid())
  playerId     String      @map("player_id")
  teamId       String      @map("team_id")
  tournamentId String?     @map("tournament_id")
  atBats       Int         @default(0, map: "ps_at_bats_df") @map("at_bats")
  runs         Int         @default(0, map: "ps_runs_df")
  hits         Int         @default(0, map: "ps_hits_df")
  h2           Int         @default(0, map: "ps_h2_df")
  h3           Int         @default(0, map: "ps_h3_df")
  hr           Int         @default(0, map: "ps_hr_df")
  rbi          Int         @default(0, map: "ps_rbi_df")
  bb           Int         @default(0, map: "ps_bb_df")
  so           Int         @default(0, map: "ps_so_df")
  hbp          Int         @default(0, map: "ps_hbp_df")
  sac          Int         @default(0, map: "ps_sac_df")
  wins         Int         @default(0, map: "ps_wins_df")
  losses       Int         @default(0, map: "ps_losses_df")
  ipOuts       Int         @default(0, map: "ps_ip_outs_df") @map("ip_outs")
  hAllowed     Int         @default(0, map: "ps_h_allowed_df") @map("h_allowed")
  erAllowed    Int         @default(0, map: "ps_er_allowed_df") @map("er_allowed")
  bbAllowed    Int         @default(0, map: "ps_bb_allowed_df") @map("bb_allowed")
  soPitching   Int         @default(0, map: "ps_so_pitching_df") @map("so_pitching")
  createdAt    DateTime    @default(now(), map: "ps_created_at_df") @map("created_at")
  updatedAt    DateTime    @default(now(), map: "ps_updated_at_df") @updatedAt @map("updated_at")
  player       Player      @relation(fields: [playerId], references: [id], onDelete: Cascade, map: "ps_player_id_fkey")
  team         Team        @relation(fields: [teamId], references: [id], onUpdate: NoAction, map: "ps_team_id_fkey")
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ps_tournament_id_fkey")

  @@unique([playerId, teamId, tournamentId], map: "player_stats_unique")
  @@index([playerId, tournamentId], map: "player_stats_player_tournament_idx")
  @@index([teamId, tournamentId], map: "player_stats_team_tournament_idx")
  @@map("player_stats")
}

model TournamentNews {
  id           String     @id @default(uuid())
  tournamentId String     @map("tournament_id")
  authorId     String?    @map("author_id")
  title        String
  description  String?    @db.NVarChar(Max)
  coverUrl     String?    @map("cover_url")
  facebookUrl  String?    @map("facebook_url")
  type         String     @default("Noticia", map: "tn_type_df") @db.NVarChar(100)
  hasVideo     Boolean    @default(false, map: "tn_has_video_df") @map("has_video")
  createdAt    DateTime   @default(now(), map: "tn_created_at_df") @map("created_at")
  author       User?      @relation(fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "tn_author_id_fkey")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade, map: "tn_tournament_id_fkey")

  @@map("tournament_news")
}

model Play {
  id             String   @id @default(uuid())
  inning         Int
  half           String   @db.NVarChar(10)
  outsBeforePlay Int      @map("outs_before_play")
  result         String
  description    String?  @db.NVarChar(Max)
  rbi            Int      @default(0)
  runsScored     Int      @default(0) @map("runs_scored")
  scored         Boolean  @default(false)
  outsRecorded   Int      @default(0) @map("outs_recorded")
  gameId         String   @map("game_id")
  batterId       String   @map("batter_id")
  pitcherId      String   @map("pitcher_id")
  timestamp      DateTime @default(now())
  batter         Player   @relation("BatterPlay", fields: [batterId], references: [id], onUpdate: NoAction)
  game           Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  pitcher        Player   @relation("PitcherPlay", fields: [pitcherId], references: [id], onUpdate: NoAction)

  @@index([gameId, inning], map: "plays_game_inning_idx")
  @@index([batterId], map: "plays_batter_idx")
  @@index([pitcherId], map: "plays_pitcher_idx")
  @@map("plays")
}

// ─────────────────────────────────────────────
// ROSTER ENTRY — Jugador global vinculado a un equipo en un torneo
// Permite reutilizar jugadores entre torneos/equipos
// Player.teamId se mantiene por compatibilidad con el sistema actual
// ─────────────────────────────────────────────
model RosterEntry {
  id           String     @id @default(uuid())
  playerId     String     @map("player_id")
  teamId       String     @map("team_id")
  tournamentId String     @map("tournament_id")
  number       Int?
  position     String?    @db.NVarChar(10)
  isActive     Boolean    @default(true) @map("is_active")
  joinedAt     DateTime   @default(now(), map: "re_joined_at_df") @map("joined_at")
  leftAt       DateTime?  @map("left_at")
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade, map: "re_player_id_fkey")
  team         Team       @relation(fields: [teamId], references: [id], onUpdate: NoAction, map: "re_team_id_fkey")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onUpdate: NoAction, map: "re_tournament_id_fkey")

  @@unique([playerId, teamId, tournamentId], map: "roster_entries_unique")
  @@index([teamId, tournamentId], map: "roster_entries_team_idx")
  @@index([playerId], map: "roster_entries_player_idx")
  @@map("roster_entries")
}

// ─────────────────────────────────────────────
// PLAN — Planes de pago (lógica de negocio pendiente)
// ─────────────────────────────────────────────
model Plan {
  id                        String   @id @default(uuid())
  name                      String   @db.NVarChar(50)
  slug                      String   @unique @db.NVarChar(50)
  price                     Float    @default(0)
  currency                  String   @default("MXN") @db.NVarChar(10)
  billingInterval           String   @default("month") @map("billing_interval") @db.NVarChar(20)
  maxActiveTournaments      Int      @default(1) @map("max_active_tournaments")
  maxTeamsPerTournament     Int      @default(8) @map("max_teams_per_tournament")
  maxPlayersPerTeam         Int      @default(15) @map("max_players_per_team")
  maxScorekeeperSlots       Int      @default(1) @map("max_scorekeeper_slots")
  facebookLiveEnabled       Boolean  @default(false) @map("facebook_live_enabled")
  bracketEnabled            Boolean  @default(false) @map("bracket_enabled")
  advancedStatsEnabled      Boolean  @default(false) @map("advanced_stats_enabled")
  customLogoEnabled         Boolean  @default(false) @map("custom_logo_enabled")
  isActive                  Boolean  @default(true) @map("is_active")
  createdAt                 DateTime @default(now()) @map("created_at")
  subscriptions             Subscription[]

  @@map("plans")
}

// ─────────────────────────────────────────────
// SUBSCRIPTION — Suscripciones de ligas a un plan
// ─────────────────────────────────────────────
model Subscription {
  id                   String    @id @default(uuid())
  leagueId             String    @map("league_id")
  planId               String    @map("plan_id")
  status               String    @default("active") @db.NVarChar(20)
  currentPeriodStart   DateTime  @map("current_period_start")
  currentPeriodEnd     DateTime  @map("current_period_end")
  externalId           String?   @map("external_id") @db.NVarChar(200)
  paymentMethod        String?   @map("payment_method") @db.NVarChar(100)
  cancelledAt          DateTime? @map("cancelled_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  league               League    @relation(fields: [leagueId], references: [id], onDelete: Cascade, map: "sub_league_id_fkey")
  plan                 Plan      @relation(fields: [planId], references: [id], onUpdate: NoAction, map: "sub_plan_id_fkey")

  @@index([leagueId], map: "subscriptions_league_idx")
  @@index([status], map: "subscriptions_status_idx")
  @@map("subscriptions")
}
